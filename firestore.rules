rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: employees
    // Fields:
    //   - name: string (required)
    //   - employeeId: string (required, unique)
    //   - department: string
    //   - position: string
    //   - createdAt: timestamp
    //
    // Collection: attendance
    // Fields:
    //   - employeeId: string (required)
    //   - employeeName: string
    //   - type: string (in/out)
    //   - timestamp: timestamp
    //   - date: string (YYYY-MM-DD)
    //
    // Collection: settings
    // Fields:
    //   - workStartTime: string (HH:mm)
    //   - workEndTime: string (HH:mm)
    //   - lateThreshold: number
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        'email' in request.auth.token &&
        request.auth.token.email.lower() == "noviharyanto062@gmail.com";
    }

    function isValidEmployee(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.employeeId is string && data.employeeId.size() > 0 && data.employeeId.size() < 50 &&
             (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('department' in data) || (data.department is string && data.department.size() < 100)) &&
             (!('position' in data) || (data.position is string && data.position.size() < 100)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp || data.createdAt == null));
    }

    function isValidAttendance(data) {
      return data.employeeId is string && data.employeeId.size() > 0 &&
             data.type in ['in', 'out'] &&
             data.timestamp is timestamp &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    function isValidSetting(data) {
      return data.workStartTimeMonThu is string && data.workStartTimeMonThu.matches("^\\d{2}:\\d{2}$") &&
             data.workEndTimeMonThu is string && data.workEndTimeMonThu.matches("^\\d{2}:\\d{2}$") &&
             data.workStartTimeFri is string && data.workStartTimeFri.matches("^\\d{2}:\\d{2}$") &&
             data.workEndTimeFri is string && data.workEndTimeFri.matches("^\\d{2}:\\d{2}$") &&
             data.lateThreshold is number &&
             (!('useGeofencing' in data) || data.useGeofencing is bool) &&
             (!('officeLat' in data) || data.officeLat is number) &&
             (!('officeLng' in data) || data.officeLng is number) &&
             (!('officeRadius' in data) || data.officeRadius is number);
    }

    function isValidUser(data) {
      return data.email is string && 
             (!('role' in data) || (data.role in ['admin', 'employee']));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read, delete: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAttendance(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /test_connection/{testId} {
      allow read, write: if isAdmin();
    }
  }
}
